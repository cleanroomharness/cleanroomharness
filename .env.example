# CleanRoom Harness environment. Copy to .env for local development.
# No real secrets belong in this file or in the repo — ever.

ENVIRONMENT=local
API_PORT=8080

# Leave empty to disable API auth in local dev.
API_AUTH_KEY=

# Model gateway (LiteLLM proxy).
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=local-dev-only
LITELLM_MASTER_KEY=local-dev-only
DEFAULT_MODEL=ollama/llama3.2:3b

# Data services.
DATABASE_URL=postgresql://cleanroom:cleanroom@localhost:5432/cleanroom
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# Side-effecting tool execution stays off unless explicitly enabled.
TOOLS_EXECUTION_ENABLED=false

# Observability.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
